{{ define "main-style" }}
  <style nonce="{{ .nonce }}">
    :root {
      --primary: cornflowerblue;
      --success: limegreen;
      --danger: salmon;
      --dark: #000000;
      --grey: #272727;
      --white: silver;

      --success-fade: #155415;
      --danger-fade: #66352E;

      --icon-small: 1.6rem;
      --icon-size: 2.4rem;
      --icon-large: 4.8rem;

      --space-size: 1rem;
    }

    * {
      box-sizing: border-box;
    }

    html {
      font-size: 62.5%;
    }

    body {
      -webkit-overflow-scrolling: touch;
      background-color: var(--dark);
      height: 100vh;
    }

    body,
    button,
    input {
      color: var(--white);
      font-family:
        -apple-system,
        'Segoe UI',
        'Roboto',
        'Oxygen-Sans',
        'Ubuntu',
        'Cantarell',
        'Helvetica Neue',
        sans-serif;
      font-size: 1.6rem;
      font-style: normal;
      font-weight: 400;
    }

    input {
      color: var(--dark);
    }

    a {
      color: var(--white);
      text-decoration: none;
    }

    a:hover {
      color: var(--primary);
      text-decoration: underline;
    }

    .primary {
      color: var(--primary);
    }

    .success {
      color: var(--success);
    }

    .danger {
      color: var(--danger);
    }

    .grey {
      color: var(--grey);
    }

    .white {
      color: var(--white);
    }

    .bg-primary,
    .bg-primary:hover {
      background-color: var(--primary);
      color: var(--dark);
      text-decoration: none;
    }

    .bg-success,
    .bg-success:hover {
      background-color: var(--success);
      color: var(--dark);
      text-decoration: none;
    }

    .bg-danger,
    .bg-danger:hover {
      background-color: var(--danger);
      color: var(--dark);
      text-decoration: none;
    }

    .bg-grey,
    .bg-grey:hover {
      background-color: var(--grey);
      color: var(--white);
      text-decoration: none;
    }

    .bg-white,
    .bg-white:hover {
      background-color: var(--white);
      color: var(--black);
      text-decoration: none;
    }

    .button {
      border-radius: 4px;
      border: 0;
      cursor: pointer;
      display: inline-block;
      margin: 0;
      padding: var(--space-size);
      text-decoration: none;
    }

    .button-icon {
      background-color: transparent;
    }

    .icon {
      background-position: center center;
      background-repeat: no-repeat;
      color: var(--white);
      display: inline-block;
      height: var(--icon-size);
      text-decoration: none;
      vertical-align: middle;
      width: var(--icon-size);
    }

    .icon-large {
      height: var(--icon-large);
      width: var(--icon-large);
    }

    .icon-small {
      height: var(--icon-small);
      width: var(--icon-small);
    }

    .icon-overlay {
      height: var(--icon-large);
      left: calc((100% - var(--icon-large)) / 2);
      pointer-events: none;
      position: absolute;
      top: calc((100% - var(--icon-large)) / 2);
      width: var(--icon-large);
    }

    .modal {
      align-items: center;
      backdrop-filter: blur(1rem);
      display: none;
      height: 100vh;
      justify-content: center;
      left: 0;
      pointer-events: none;
      position: fixed;
      top: 0;
      width: 100vw;
    }

    .modal-content {
      background-color: var(--dark);
      display: flex;
      flex-direction: column;
      max-height: 100%;
      max-width: 100%;
      pointer-events: auto;
    }

    .header {
      background-color: var(--grey);
      margin-top: 0;
      padding: calc(var(--space-size) / 2) var(--space-size);
      text-align: left;
    }

    .block {
      display: block;
    }

    .flex {
      align-items: center;
      display: flex;
    }

    .flex-center {
      justify-content: center;
    }

    .flex-grow {
      flex: 1 1;
    }

    .center {
      text-align: center;
    }

    .padding {
      padding: var(--space-size);
    }

    .padding-half {
      padding: calc(var(--space-size) / 2);
    }

    .no-padding {
      padding: 0;
    }

    .margin-auto {
      margin: 0 auto;
    }

    .margin {
      margin: var(--space-size);
    }

    .margin-top {
      margin-top: var(--space-size);
    }

    .margin-right {
      margin-right: var(--space-size);
    }

    .margin-bottom {
      margin-bottom: var(--space-size);
    }

    .margin-left {
      margin-left: var(--space-size);
    }

    .margin-half {
      margin: calc(var(--space-size) / 2);
    }

    .no-margin {
      margin: 0;
    }

    .ellipsis {
      overflow: hidden;
      text-align: left;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .full {
      width: 100%;
    }

    @media print {
      body::after {
        content: 'Save ink, share link. {{ publicURL "" }}';
      }

      body > * {
        display: none !important;
      }
    }
  </style>
{{ end }}

{{ define "main-script" }}
  <script type="text/javascript" nonce="{{ .nonce }}">
    function goBack() {
      const previousHash = document.location.hash;
      document.location.hash = "";

      if (/success$/gim.test(previousHash)) {
        window.location.reload(true);
      }
    }

    window.onkeyup = (e) => {
      switch (e.key) {
        case "Escape":
          goBack();
          break;
      }
    };

    document.addEventListener("readystatechange", async (event) => {
      if (event.target.readyState === "complete") {
        const link = document.getElementById("go-back");
        if (link) {
          link.setAttribute("href", document.referrer);
          link.addEventListener("click", (e) => {
            e.preventDefault();
            history.back();
            return false;
          });
        }
      }
    });
  </script>
{{ end }}

{{ define "header" }}
  <!doctype html>
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="format-detection" content="telephone=no">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

      {{ template "seo" . }}
      {{ template "favicon" . }}

      {{ template "main-style" . }}
      {{ template "main-script" . }}
    </head>

    <body class="no-margin">
      <div class="content">
        <header class="flex padding">
          <h1 class="no-margin no-padding">
            <a href="{{ url "" }}{{ with .Root }}{{ . }}{{ end }}" class="no-style clear">{{ .Title }}</a>
          </h1>

          <span class="flex-grow"></span>

          {{ template "header-part" . }}
        </header>
{{ end }}

{{ define "footer" }}
    </div>
  </body>

</html>
{{ end }}

{{ define "message" }}
  {{ with . }}
    {{ if gt (len .Content) 0 }}
      <p class="message no-margin padding center {{ if eq .Level "error" }}bg-danger{{ else }}success{{ end }}">
        {{ .Content }}
      </p>
    {{ end }}
  {{ end }}
{{ end }}

{{ define "public" }}
  {{ template "header" . }}

  {{ template "message" .Message }}
  {{ template "app" . }}

  {{ template "footer" . }}
{{ end }}

{{ define "error" }}
  {{ template "header" . }}
  {{ template "message" .Message }}

  {{ with .Errors }}
    {{ range .Errors }}
      <p class="padding no-margin center">
        {{ . }}
      </p>
    {{ end }}
  {{ end }}

  <h3 class="center">
    <a id="go-back" href="#">Go Back</a>
  </h3>

  {{ template "footer" . }}
{{ end }}

{{ define "header-redirect" }}
  <!doctype html>
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="format-detection" content="telephone=no">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

      <meta http-equiv="refresh" content="3;url={{ .Redirect }}">

      {{ template "seo" . }}
      {{ template "favicon" . }}

      {{ template "main-style" . }}
      {{ template "main-script" . }}
    </head>

    <body class="no-margin">
      <div class="content">
        <header class="flex padding">
          <h1 class="no-margin no-padding">
            <a href="{{ url "" }}{{ with .Root }}{{ . }}{{ end }}" class="no-style clear">{{ .Title }}</a>
          </h1>

          <span class="flex-grow"></span>

          {{ template "header-part" . }}
        </header>
{{ end }}

{{ define "auth" }}
  {{ if .Providers }}
    {{ template "header" . }}
  {{ else }}
    {{ template "header-redirect" . }}
  {{ end }}

  {{ template "message" .Message }}

  <style nonce="{{ .nonce }}">
    .square {
      height: 15rem;
      width: 15rem;
    }
  </style>

  <article class="flex flex-center">
    {{ if .Providers }}
      <div class="center">
        <h2 class="no-margin margin-bottom">Sign in with</h2>

        {{ range .Providers }}
          <a class="button flex flex-center bg-white margin-top square" href="{{ .URL }}">
            {{ if eq .Name "Google" }}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59a14.5 14.5 0 0 1 0-9.18l-7.98-6.19a24.01 24.01 0 0 0 0 21.56l7.98-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            {{ else if eq .Name "Discord" }}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 126.644 96"><path fill="#5865f2" d="M81.15 0a74 74 0 0 0-3.36 6.794 97.9 97.9 0 0 0-28.994 0A68 68 0 0 0 45.437  0a105.6 105.6 0 0 0-26.14 8.057C2.779 32.53-1.691 56.373.53 79.887a105 105 0 0 0 32.05 16.088 77 77 0 0 0 6.87-11.063c-3.738-1.389-7.35-3.131-10.81-5.152.91-.657  1.794-1.338 2.653-1.995a75.26 75.26 0 0 0 64.075 0c.86.707 1.743 1.389 2.652 1.995a69 69 0 0 1-10.835 5.178A77 77 0 0 0 94.056 96a105 105 0 0 0  32.051-16.063c2.626-27.277-4.496-50.917-18.817-71.855A104 104 0 0 0 81.175.05zM42.28 65.414c-6.238 0-11.416-5.657-11.416-12.653s4.976-12.679 11.391-12.679 11.517  5.708 11.416 12.679c-.101 6.97-5.026 12.653-11.39 12.653m42.078 0c-6.264 0-11.391-5.657-11.391-12.653s4.975-12.679 11.39-12.679S95.85 45.79 95.749 52.761c-.1  6.97-5.026 12.653-11.39 12.653"/></svg>
            {{ else if eq .Name "GitHub" }}
              <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" fill="none" viewBox="0 0 98 96"><g clip-path="url(#a)"><path fill="#000" d="M41.44   69.385C28.807 67.853 19.906 58.762 19.906 46.99c0-4.785 1.723-9.953 4.594-13.398-1.244-3.158-1.053-9.858.383-12.633 3.828-.479 8.996 1.531 12.058 4.307 3.637-1.149   7.465-1.723 12.155-1.723s8.517.574 11.963 1.627c2.966-2.68 8.23-4.69 12.058-4.211 1.34 2.584 1.531 9.283.287 12.537 3.063 3.637 4.69 8.518 4.69 13.494 0 11.772-8.9   20.672-21.725 22.3 3.254 2.104 5.455 6.698 5.455 11.962v9.953c0 2.871 2.393 4.498 5.264 3.35C84.41 87.95 98 70.629 98 49.19 98 22.107 75.988 0 48.904 0S0 22.107 0  49.191c0 21.246 13.494 38.856 31.678 45.46 2.584.956 5.072-.766 5.072-3.35v-7.657c-1.34.575-3.062.958-4.594.958-6.316  0-10.049-3.446-12.728-9.858-1.053-2.584-2.201-4.115-4.403-4.402-1.148-.096-1.53-.574-1.53-1.149 0-1.148 1.913-2.01 3.827-2.01 2.776 0 5.168 1.723 7.657 5.264 1.914  2.776 3.923 4.02 6.316 4.02s3.924-.861 6.125-3.063c1.627-1.627 2.871-3.062 4.02-4.02"/></g><defs><clipPath id="a"><path fill="#fff" d="M0 0h98v96H0z"/></clipPath></defs></svg>
            {{ else }}
              {{ .Name }}
            {{ end }}
          </a>
        {{ end }}
      </div>
    {{ else }}
      <div>
        {{ with .Image }}
          <img class="square" src="{{ . }}">
        {{ end }}

        <a class="button bg-primary block margin-top" href="{{ .Redirect }}">Redirect in 3s...</a>
      </div>
    {{ end }}
  </article>

  {{ template "footer" . }}
{{ end }}
